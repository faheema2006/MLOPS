# YOLO Docker Configuration File
# Customize these settings for your deployment

# Docker Configuration
DOCKER_USERNAME=your_docker_username
DOCKER_REPO=yolo-inference
DOCKER_TAG=latest
DOCKER_REGISTRY=docker.io

# Image Configuration
IMAGE_NAME=${DOCKER_USERNAME}/${DOCKER_REPO}:${DOCKER_TAG}
BUILD_CONTEXT=.
DOCKERFILE_PATH=Dockerfile

# Container Configuration
CONTAINER_NAME=yolo-inference-api
CONTAINER_PORT=5000
HOST_PORT=5000

# Model Configuration
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.4
INPUT_FORMAT=jpg,jpeg,png,mp4,avi,mov

# Directory Configuration
INPUT_DIR=./inputs
OUTPUT_DIR=./outputs
MODEL_DIR=./models

# Memory and Resource Limits
MAX_FILE_SIZE=524288000  # 500MB in bytes
MEMORY_LIMIT=2g
CPU_LIMIT=2

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false
WORKERS=4

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=production  # development, staging, production
PYTHONUNBUFFERED=1

# Deployment Settings
PUSH_AFTER_BUILD=false
CREATE_TAGS=latest,v1.0
REMOVE_OLD_IMAGES=true

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=yolo
COMPOSE_FILE=docker-compose.yml

# Registry Settings
REGISTRY_URL=https://registry.hub.docker.com
REGISTRY_AUTH_ENABLED=true
